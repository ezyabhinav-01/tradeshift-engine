# Shoonya/Finvasia API Credentials
# Copy this file to .env and fill in your actual credentials

# Your Shoonya User ID
SHOONYA_USER_ID=FN130135

# Your Shoonya Password
SHOONYA_PASSWORD=@Mannat05@

# Vendor Code (provided by Shoonya)
SHOONYA_VENDOR_CODE=FN130135_U

# API Secret (provided by Shoonya)
SHOONYA_API_SECRET=3421660f02d25cda2d66f1f7cc2df535

# TOTP Secret for 2FA (Base32 encoded secret from your authenticator app setup)
# This is the secret key shown when you set up 2FA, NOT the 6-digit code
SHOONYA_TOTP_SECRET=G76672TO567JA6EUO3LFR6N3I467M6SG

# IMEI (optional, defaults to 'abc1234')
SHOONYA_IMEI=abc1234

# Database Configuration (already in docker-compose.yml)
NEWSAPI_KEY=a5238894-c371-4755-8450-479406ff723c
ALPHA_VANTAGE_KEY=QF8BTCX1PZVSKO2A
NEWSDATA_API_KEY=your_newsdata_api_key
USE_NEWSAPI_FALLBACK=false

# DB pooling (Supabase-safe defaults)
DB_USE_NULL_POOL=true
DB_USE_NULL_POOL_SYNC=true
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_SIZE_SYNC=2
DB_MAX_OVERFLOW_SYNC=1
DB_POOL_TIMEOUT_SYNC=30
DB_POOL_RECYCLE_SYNC=1800

# Background workload controls (avoid duplicate schedulers across instances)
RUN_BACKGROUND_JOBS=true
RUN_ASYNC_SCHEDULER=true
RUN_ASYNC_STARTUP_SYNC=false
ENABLE_COMMUNITY_SEED=true
REDIS_URL=redis://localhost:6379
FIN_GPT_URL=http://localhost:8000/generate  # adjust to your FinGPT endpoint
