# Copy this file to backend/.env and fill with real credentials.
# Never commit real secrets.

# App mode and security
APP_ENV=beta
SECRET_KEY=replace_with_strong_32_plus_char_secret
COOKIE_SECURE=true
HSTS_ENABLED=true
COOKIE_SAMESITE=lax
CORS_ALLOWED_ORIGINS=https://tradeshift-india.netlify.app
AUTH_AI_SIDE_EFFECTS_ENABLED=false
ADMIN_SERVICE_KEY=replace_with_strong_internal_admin_key
CHATBOT_API_KEY=replace_with_chatbot_service_key

# Database (Supabase)
# Direct connection (if needed):
# DATABASE_URL=postgresql://postgres:<NEW_DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
# Transaction pooler (recommended for app workloads):
DATABASE_URL=postgresql://postgres.<project-ref>:<NEW_DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# DB pooling defaults (safe for provider poolers)
DB_USE_NULL_POOL=true
DB_USE_NULL_POOL_SYNC=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_SIZE_SYNC=5
DB_MAX_OVERFLOW_SYNC=5
DB_POOL_TIMEOUT_SYNC=30
DB_POOL_RECYCLE_SYNC=1800

# Replay/load controls (100-user beta defaults)
REPLAY_MAX_CONCURRENT_SESSIONS=100
REPLAY_MAX_THREAD_WORKERS=8
REPLAY_AI_MAX_CONCURRENCY=4
REPLAY_START_SUCCESS_THRESHOLD=0.95
WS_SEND_TIMEOUT_SECONDS=1.0
HTTP_REQUEST_TIMEOUT_SECONDS=25

# Email
MAIL_USERNAME=replace_with_sender_email
MAIL_PASSWORD=replace_with_sender_app_password
MAIL_FROM=replace_with_sender_email
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=TradeShift

# Shoonya/Finvasia API credentials
SHOONYA_USER_ID=replace_with_shoonya_user_id
SHOONYA_PASSWORD=replace_with_shoonya_password
SHOONYA_VENDOR_CODE=replace_with_vendor_code
SHOONYA_API_SECRET=replace_with_api_secret
SHOONYA_TOTP_SECRET=replace_with_totp_secret
SHOONYA_IMEI=replace_with_device_imei

# External market/news API keys
NEWSAPI_KEY=replace_with_newsapi_key
ALPHA_VANTAGE_KEY=replace_with_alpha_vantage_key
NEWSDATA_API_KEY=replace_with_newsdata_api_key
USE_NEWSAPI_FALLBACK=false

# AI keys
GEMINI_API_KEY=replace_with_gemini_key
HUGGINGFACE_API_KEY=replace_with_huggingface_key

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_SOCKET_TIMEOUT_SECONDS=1.5
REDIS_CONNECT_TIMEOUT_SECONDS=1.5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=replace_with_minio_access_key
MINIO_SECRET_KEY=replace_with_minio_secret_key
MINIO_BUCKET=market-data

# Background workload controls
RUN_BACKGROUND_JOBS=true
RUN_ASYNC_SCHEDULER=true
RUN_ASYNC_STARTUP_SYNC=false
ENABLE_COMMUNITY_SEED=false
