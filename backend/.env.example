# Copy this file to .env and fill in your actual credentials.
# Never commit real credentials to git.

# App mode
APP_ENV=production
SECRET_KEY=replace_with_long_random_secret

# Shoonya/Finvasia API Credentials
SHOONYA_USER_ID=your_shoonya_user_id
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_API_SECRET=your_api_secret
SHOONYA_TOTP_SECRET=your_totp_secret
SHOONYA_IMEI=abc1234

# External market/news API keys
NEWSAPI_KEY=your_newsapi_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
NEWSDATA_API_KEY=your_newsdata_api_key
USE_NEWSAPI_FALLBACK=false

# AI keys
GEMINI_API_KEY=your_gemini_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Database
# Example: postgresql://user:password@db:5432/tradeshift
DATABASE_URL=postgresql://user:password@db:5432/tradeshift

# DB pooling (100-user prototype safe defaults)
DB_USE_NULL_POOL=false
DB_USE_NULL_POOL_SYNC=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_SIZE_SYNC=5
DB_MAX_OVERFLOW_SYNC=5
DB_POOL_TIMEOUT_SYNC=30
DB_POOL_RECYCLE_SYNC=1800

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_SOCKET_TIMEOUT_SECONDS=1.5
REDIS_CONNECT_TIMEOUT_SECONDS=1.5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=market-data

# Runtime controls
HTTP_REQUEST_TIMEOUT_SECONDS=25
REPLAY_MAX_CONCURRENT_SESSIONS=8
REPLAY_MAX_THREAD_WORKERS=8
REPLAY_AI_MAX_CONCURRENCY=4
WS_SEND_TIMEOUT_SECONDS=1.0
UVICORN_RELOAD=false

# Background workload controls
RUN_BACKGROUND_JOBS=true
RUN_ASYNC_SCHEDULER=true
RUN_ASYNC_STARTUP_SYNC=false
ENABLE_COMMUNITY_SEED=false
